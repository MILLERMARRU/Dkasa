---
const proyectos = [
  { src: '/images/proyecto-1.jpg', alt: 'Fachada exterior — vivienda dos pisos', tag: 'Exterior', grande: true  },
  { src: '/images/proyecto-2.jpg', alt: 'Sala comedor — planta libre', tag: 'Interior', grande: false },
  { src: '/images/proyecto-3.jpg', alt: 'Cocina con muebles a medida', tag: 'Cocina',   grande: false },
  { src: '/images/proyecto-4.jpg', alt: 'Escalera con pasamanos metálico', tag: 'Escaleras', grande: false },
  { src: '/images/proyecto-5.jpg', alt: 'Sala principal con luz natural', tag: 'Sala',   grande: false },
  { src: '/images/proyecto-6.jpg', alt: 'Vista interior 3D de acabados', tag: '3D',     grande: true  },
]
---

<section id="proyectos" class="proyectos">
  <div class="proyectos__header">
    <p class="section-label reveal">Proyectos</p>
    <h2 class="proyectos__title reveal reveal-delay-1">
      Renders y acabados<br />
      <span>que hablan solos</span>
    </h2>
    <p class="proyectos__sub reveal reveal-delay-2">
      Visualización 3D fotorrealista de cada proyecto antes de construir.
      Así sabes exactamente cómo quedará tu hogar.
    </p>
  </div>

  <div class="proyectos__grid">
    {proyectos.map((p, i) => (
      <figure
        class={`proyectos__item reveal reveal-delay-${(i % 3) + 1} ${p.grande ? 'proyectos__item--grande' : ''}`}
        style={`--index: ${i}`}
      >
        <img
          src={p.src}
          alt={p.alt}
          loading="lazy"
          decoding="async"
        />
        <figcaption>
          <span class="proyectos__tag">{p.tag}</span>
          <span class="proyectos__alt">{p.alt}</span>
        </figcaption>
      </figure>
    ))}
  </div>

  <div class="proyectos__bottom reveal">
    <p>¿Quieres ver tu terreno hecho vivienda? Diseñamos tu render antes de presupuestar.</p>
    <a href="#contacto" class="proyectos__cta">
      Pedir visualización 3D
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .proyectos {
    background: var(--color-carbon);
    color: var(--color-bone);
    padding: 8rem 0;
  }

  .proyectos__header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 6vw 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .proyectos__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-bone);
  }

  .proyectos__title span { color: rgba(245, 242, 238, 0.3); }

  .proyectos__sub {
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(245, 242, 238, 0.45);
    max-width: 500px;
  }

  /* Grid de imágenes */
  .proyectos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--color-carbon);
  }

  .proyectos__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    cursor: default;
  }

  .proyectos__item--grande {
    grid-column: span 2;
  }

  .proyectos__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out);
    display: block;
  }

  .proyectos__item:hover img {
    transform: scale(1.04);
  }

  /* Caption */
  figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(20,20,18,0.75) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .proyectos__item:hover figcaption {
    opacity: 1;
    transform: translateY(0);
  }

  .proyectos__tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-madera);
    background: rgba(20,20,18,0.6);
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
  }

  .proyectos__alt {
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(245, 242, 238, 0.7);
    max-width: 60%;
    text-align: right;
  }

  /* Bottom */
  .proyectos__bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 6vw 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid rgba(245, 242, 238, 0.08);
    margin-top: 2px;
  }

  .proyectos__bottom p {
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(245, 242, 238, 0.4);
    max-width: 440px;
  }

  .proyectos__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-carbon);
    background: var(--color-bone);
    border-radius: 3px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .proyectos__cta:hover {
    background: var(--color-madera);
    color: var(--color-white);
    transform: scale(0.98);
  }

  @media (max-width: 900px) {
    .proyectos__grid { grid-template-columns: repeat(2, 1fr); }
    .proyectos__item--grande { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .proyectos { padding: 5rem 0; }
    .proyectos__grid { grid-template-columns: 1fr; }
    .proyectos__item--grande { grid-column: span 1; }
    .proyectos__bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
